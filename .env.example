# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000

# Supabase project URL and anon/public key (Settings → API in the Supabase
# dashboard) — used only to initiate Google OAuth and read the callback
# session. See README.md "Google OAuth Setup" for the full setup guide.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
